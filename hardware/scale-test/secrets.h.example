#pragma once

// Template for secrets.h. Copy this file to `secrets.h` and fill in your
// own values. `secrets.h` is gitignored — never commit real credentials.
//
//   cp secrets.h.example secrets.h
//   <edit secrets.h with your WiFi info>

#define WIFI_SSID      "your-wifi-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// OTA upload password — leave empty for unprotected LAN-only flashing.
// Set to a non-empty value to require auth on every OTA flash.
#define OTA_PASSWORD   ""

// Stock Manager addon — direct HTTP base URL of the addon (port 8099, NOT
// HA's 8123) and the scale id auto-assigned when you create the scale in
// the addon's Basculas tab.
//   Example: ADDON_BASE_URL "http://192.168.1.29:8099"
//            SCALE_ID 1
// Leave ADDON_BASE_URL empty to disable webhook posts (standalone mode).
#define ADDON_BASE_URL ""
#define SCALE_ID       1
